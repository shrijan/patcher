+<?php
+
+use Symfony\Component\HttpFoundation\RequestStack;
+
+/**
+ * Implements hook_preprocess_sitemap().
+ */
+function dphi_base_theme_preprocess_sitemap(array &$variables) {
+  // Get the current request
+  $request = \Drupal::service('request_stack')->getCurrentRequest();
+
+  // Get the title using the TitleResolver service
+  $title = \Drupal::service('title_resolver')->getTitle($request, \Drupal::routeMatch()->getRouteObject());
+
+  // Fallback if title is not available
+  if (!$title) {
+    $title = \Drupal::routeMatch()->getRouteName();
+  }
+
+  // Pass the title to the Twig template
+  $variables['sitemap_title'] = $title;
+}
