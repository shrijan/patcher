{{ attach_library('dphi_base_theme/component.card_carousel') }}
{% if cardList.title %}
  <h2>{{ cardList.title }}</h2>
{% endif %}
<div class="description-{% if cardList.description_on_left %}75{% else %}50{% endif %}">
  {{ cardList.description|raw }}
</div>
{% set cards = cardList.cards %}

{% if cards|length %}
  <div class="nsw-carousel-container">
    <p class="sr-only">Carousel items</p>
      <div class="nsw-carousel js-carousel" data-description="Highlighted latest news" data-drag="on" >
        <div class="nsw-carousel__wrapper js-carousel__wrapper">
          <ol class="nsw-carousel__list">
            {% for card in cards %}

              <li class="nsw-carousel__item">
              <div class="nsw-card {% if card.theme %}nsw-card--{{ card.theme }}{% endif %} nsw-card--headline {% if card.link is empty or card.link.toString is empty %} no-link {% endif %} ">
                {% if card.image %}
                <div class="nsw-card__image">
                    {% set classes = [
                      'nsw-card__image',
                      card.camera_icon ? 'show-camera-icon' : 'hide-camera-icon',
                      card.image_fullHeight ? 'fullHeight' : ''
                    ] %}
                    <div class="{{ classes|join(' ') }}">
                      {% if card.image.url %}
                        <img src="{{ card.image.url }}" alt="{{ card.image.alt }}"/>
                      {% else %}
                        {{ card.image }}
                      {% endif %}
                    </div>
                </div>
                {% endif %}
                <div class="nsw-card__content">
                  <div class="nsw-card__title">
                    {% if card.number %}
                      <div class="nsw-m-bottom-sm nsw-h2">{{ card.number }}</div>
                    {% endif %}
                    {% if card.icon %}
                      <span class="nsw-material-icons nsw-position-static nsw-m-bottom-md {{ card.iconClasses }} {{ card.iconOutlined ? 'material-symbols-outlined' : 'material-icons' }}"
                            focusable="false" aria-hidden="true">{{ card.icon }}</span>
                    {% endif %}
                    <a href="{{ card.link }}" class="nsw-display-block">{{ card.title }}</a>
                    {% if card.tags %}
                      {% include '@dphi_base_theme/components/component--tags.html.twig' with {tags: card.tags} %}
                    {% endif %}
                  </div>
                  {% if card.description %}
                    <div class="nsw-card__copy">
                      {{ card.description }}
                    </div>
                  {% endif %}
                  {% if card.endIcon %}
                    <span class="material-icons nsw-material-icons"
                          focusable="false" aria-hidden="true">{{ card.endIcon }}</span>
                  {% endif %}
                </div>
              </div>
              </li>
            {% endfor %}
          </ol>
        </div>
        <nav>
          <ul>
            <li>
              <button aria-controls="nsw-carousel__list" aria-label="Show previous items" class="nsw-carousel__control nsw-carousel__control--prev js-carousel__control">
                <svg class="nsw-icon" viewBox="0 0 20 20">
                  <title>Show previous items</title>
                  <polyline points="13 2 5 10 13 18" fill="none" stroke="currentColor" stroke-linecap="square" stroke-linejoin="square" stroke-width="2" />
                </svg>
              </button>
            </li>
            <li>
              <button aria-controls="nsw-carousel__list" aria-label="Show next items" class="nsw-carousel__control nsw-carousel__control--next js-carousel__control">
                <svg class="nsw-icon" viewBox="0 0 20 20">
                  <title>Show next items</title>
                  <polyline points="7 2 15 10 7 18" fill="none" stroke="currentColor" stroke-linecap="square" stroke-linejoin="square" stroke-width="2" />
                </svg>
              </button>
            </li>
          </ul>
        </nav>
    </div>
  </div>
{% endif %}
