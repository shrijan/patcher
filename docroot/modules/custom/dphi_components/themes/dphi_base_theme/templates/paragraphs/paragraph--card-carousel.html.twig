{% set cardList = paragraph.getComponent() %}
<section class="nsw-section cards {% if cardList.background_theme == 1 %}
		nsw-bg--brand-light
		{% elseif cardList.background_theme == 2 %}
		nsw-bg--brand-dark nsw-text--light
		{% elseif cardList.background_theme == 3 %}
		nsw-bg--off-white
		{% endif %}
	{{ paragraph.getPaddingControlClass() }}">
	<div class="nsw-container nsw-p-y-sm">
		<div class="nsw-layout">
			<div class="nsw-layout__main">
    		{% include '@dphi_base_theme/components/component--card-carousel.html.twig' %}
      </div>
    </div>
	</div>
</section>
